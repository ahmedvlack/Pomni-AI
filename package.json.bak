{
  "name": "Pomni AI",
  "version": "1.0.1",
  "description": "Simple WhatsApp bot by Venom / VA - Modified by VENi",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "preinstall": "npm install --cpu=wasm32 --arch=wasm32 --no-save @img/sharp-wasm32@0.34.5 sharp@0.34.5 --force",
    "postinstall": "npm install --cpu=wasm32 --arch=wasm32 wa-sticker-formatter@4.4.4 --save --force",
    "start": "node index.js"
  },
  "keywords": ["whatsapp-bot", "termux","bot"],
  "author": "VENi - youssefv",
  "license": "MIT",
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "chokidar": "^5.0.0",
    "file-type": "^18.0.0",
    "form-data": "^4.0.5",
    "qs": "*",
    "wa-sticker-formatter": "^4.4.4",
    "whatsappy": "github:deveni0/ws"
  },
  "overrides": {
    "wa-sticker-formatter": {
      "sharp": "0.34.5"
    }
  }
}